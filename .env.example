# ─── Aether Energy — Environment Configuration ──────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ─── Runtime ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info                    # trace | debug | info | warn | error | fatal
TRUST_PROXY=1                     # 1 = trust first proxy hop (Traefik). Set higher if chained.

# ─── Database ───────────────────────────────────────────────────────────
# postgres://USER:PASS@HOST:PORT/DBNAME?sslmode=require
# Native install: postgres://aether:STRONG_PASS@localhost:5433/aether_energy
DATABASE_URL=postgres://aether:CHANGE_ME@localhost:5433/aether_energy

# Connection pool (pgBouncer or pg.Pool)
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=30000

# ─── Redis (cache, idempotency, lockout, pub/sub) ──────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_WITH_48_BYTES_OF_RANDOM_BASE64
JWT_EXPIRES_IN=7d
ALLOW_REGISTRATION=true           # false to disable /api/auth/register (invite-only)

# ─── CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowlist. NEVER use * in production.
# Example: https://aether-energy.ai,https://www.aether-energy.ai
CORS_ORIGIN=https://aether-energy.ai

# ─── Email (transactional — password reset, alerts) ────────────────────
# Optional but recommended. Use Postmark/SES/SendGrid.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Aether Energy <noreply@aether-energy.ai>

# ─── Observability ──────────────────────────────────────────────────────
# Sentry (errors + performance). Get from sentry.io. Leave empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1    # 10% of transactions
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── Real-time data (Phase 1+ from roadmap) ────────────────────────────
# EIA API v2 — energy fundamentals (free, 2,500 req/day)
EIA_API_KEY=
# NewsAPI — headlines (free 100 req/day)
NEWSAPI_KEY=
# GDELT — global events (free, unlimited, no key)
# GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# ─── Security ───────────────────────────────────────────────────────────
# CSP_REPORT_ONLY=true  → report violations but don't block (good for migration)
CSP_REPORT_ONLY=false

# ─── Feature flags ──────────────────────────────────────────────────────
ENABLE_2FA=true
ENABLE_REGISTRATION=true
ENABLE_ADMIN_API=true

# ─── Demo / dev ─────────────────────────────────────────────────────────
DEMO_USER_ID=demo-user-id
ADMIN_USER_ID=admin-user-id
